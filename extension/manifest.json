{
  "manifest_version": 3,
  "name": "Kiki",
  "version": "1.0.0",
  "description": "Web accessibility through voice. Say \"Kiki\" to click, type, scroll, and navigate any website — no mouse or keyboard required.",
  "permissions": [
    "offscreen",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/accessibility-tree.js",
        "content/action-executors.js",
        "content/action-dispatcher.js",
        "content/safety-gate.js",
        "content/label-overlay.js",
        "content/chat-window.js",
        "content/content-script.js"
      ],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fonts/*.woff2"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Kiki"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
